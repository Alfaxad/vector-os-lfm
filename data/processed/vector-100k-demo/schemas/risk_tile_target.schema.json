{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VectorOS RiskTile target schema for scaled LFM2.5-VL SFT",
  "type": "object",
  "required": [
    "schema_version",
    "risk_tile_id",
    "disease_module",
    "risk",
    "signals",
    "recommended_actions",
    "limitations",
    "audit"
  ],
  "properties": {
    "schema_version": {
      "const": "vectoros-risk-tile-v0.2"
    },
    "risk_tile_id": {
      "type": "string"
    },
    "disease_module": {
      "type": "string"
    },
    "risk": {
      "type": "object",
      "required": [
        "score",
        "class",
        "confidence",
        "uncertainty_interval"
      ]
    },
    "signals": {
      "type": "object"
    },
    "recommended_actions": {
      "type": "array",
      "minItems": 1
    },
    "limitations": {
      "type": "array",
      "minItems": 1
    },
    "audit": {
      "type": "object"
    }
  }
}
